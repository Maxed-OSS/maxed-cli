{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://maxed-oss.github.io/maxed-cli/schemas/workpaper.schema.json",
  "title": "Workpaper spec",
  "description": "A declarative spec describing a single accounting workpaper: its sections, the line items each section expects, and simple structural checks. Firm-agnostic and free of real client data.",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "id", "title", "sections"],
  "properties": {
    "spec_version": {
      "type": "integer",
      "enum": [1],
      "description": "Workpaper spec schema version."
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_-]{1,48}$",
      "description": "Stable workpaper identifier, e.g. 'WP-CASH-RECON'."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable workpaper title."
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}(-(Q[1-4]|[0-9]{2}))?$",
      "description": "Optional reporting period, e.g. '2025', '2025-Q2', or '2025-06'."
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 currency code, e.g. 'USD'.",
      "default": "USD"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered sections of the workpaper.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "line_items"],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]{0,48}$",
            "description": "Machine key, unique within the workpaper."
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "Display label for the section."
          },
          "line_items": {
            "type": "array",
            "minItems": 1,
            "description": "Line items expected in this section.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ref", "label", "type"],
              "properties": {
                "ref": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9_.]{0,64}$",
                  "description": "Reference key, unique within the workpaper."
                },
                "label": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Display label for the line item."
                },
                "type": {
                  "type": "string",
                  "enum": ["amount", "text", "date", "percent", "boolean"],
                  "description": "Expected data type of the value."
                },
                "required": {
                  "type": "boolean",
                  "default": true,
                  "description": "Whether the value must be present."
                }
              }
            }
          }
        }
      }
    }
  }
}
